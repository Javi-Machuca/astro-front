---
import Layout from '../../layouts/Layout.astro';
---

<Layout titulo="Reservas – Admin · Gestora de Vuelos">
  <div class="admin-wrap">
    <header class="page-header">
      <div>
        <h1>Reservas en SAP</h1>
        <p class="subtitle">Listado completo de reservas registradas en ZCARRITO_JMG</p>
      </div>
      <div id="contador" class="contador"></div>
    </header>

    <div class="card toolbar">
      <input type="text" id="search" placeholder="Buscar por nombre, DNI o vuelo…" />
    </div>

    <div class="card table-card">
      <div id="loading" class="loading-state">Cargando reservas…</div>
      <div id="error-state" class="error-state" style="display:none"></div>
      <div id="table-wrap" style="display:none">
        <div class="tabla-header">
          <span class="tabla-titulo">Todas las reservas</span>
          <span id="result-count" class="tabla-info"></span>
        </div>
        <div class="tabla-scroll">
          <table>
            <thead>
              <tr>
                <th>ID Carrito</th>
                <th>Vuelo ID</th>
                <th>Nombre</th>
                <th>DNI</th>
                <th>Cantidad</th>
                <th>Precio total</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="reservas-tbody"></tbody>
          </table>
        </div>
        <div class="pie">
          <div class="paginacion">
            <button id="btn-prev" class="pag-btn" aria-label="Anterior">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 18l-6-6 6-6"></path>
              </svg>
            </button>
            <span id="pag-info" class="pag-info"></span>
            <button id="btn-next" class="pag-btn" aria-label="Siguiente">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18l6-6-6-6"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Dialog de confirmación -->
  <div id="confirm-dialog" class="dialog-overlay" style="display:none">
    <div class="dialog-box">
      <p class="dialog-titulo">¿Eliminar reserva?</p>
      <p class="dialog-sub">
        Se eliminará la reserva de <strong id="dialog-nombre"></strong> de SAP. Esta acción no se puede deshacer.
      </p>
      <div class="dialog-actions">
        <button class="dialog-btn-cancel" id="dialog-cancelar">Cancelar</button>
        <button class="dialog-btn-confirm" id="dialog-confirmar">Sí, eliminar</button>
      </div>
    </div>
  </div>
</Layout>

<script>
  // La peticion al proxy se hace desde el navegador; el acceso esta protegido por la cookie de sesion de admin
  const PROXY_URL = import.meta.env.PUBLIC_PROXY_URL || 'http://localhost:3001';
  const API_TOKEN = import.meta.env.PUBLIC_API_TOKEN || '';

  interface Reserva {
    idCarrito: string;
    vueloId: string;
    nombre: string;
    dni: string;
    cantidad: number;
    precioTotal: number;
  }

  // Estado de la tabla: allReservas contiene todos los registros de SAP; filtered es el subconjunto visible tras el buscador
  let allReservas: Reserva[] = [];
  let filtered: Reserva[] = [];
  const PER_PAGE = 15;
  let page = 1;

  const tbody = document.getElementById('reservas-tbody') as HTMLTableSectionElement;
  const loadingEl = document.getElementById('loading') as HTMLDivElement;
  const errorEl = document.getElementById('error-state') as HTMLDivElement;
  const tableWrap = document.getElementById('table-wrap') as HTMLDivElement;
  const pagInfo = document.getElementById('pag-info') as HTMLSpanElement;
  const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const contadorEl = document.getElementById('contador') as HTMLDivElement;
  const resultCount = document.getElementById('result-count') as HTMLSpanElement;

  // Filtra las reservas en memoria por texto libre contra nombre, DNI, vuelo ID e ID carrito
  function applyFilter() {
    const q = searchInput.value.toLowerCase();
    filtered = allReservas.filter((r) => {
      return (
        !q ||
        r.nombre.toLowerCase().includes(q) ||
        r.dni.toLowerCase().includes(q) ||
        r.vueloId.toLowerCase().includes(q) ||
        r.idCarrito.toLowerCase().includes(q)
      );
    });
    page = 1;
    render();
  }

  // Renderiza la pagina actual de la tabla con sus filas y actualiza contadores y controles de paginacion
  function render() {
    const total = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
    const start = (page - 1) * PER_PAGE;
    const slice = filtered.slice(start, start + PER_PAGE);

    contadorEl.textContent = `${filtered.length} reserva${filtered.length !== 1 ? 's' : ''}`;
    resultCount.textContent = `${filtered.length} resultado${filtered.length !== 1 ? 's' : ''}`;
    pagInfo.textContent = `${page} / ${total}`;
    btnPrev.disabled = page <= 1;
    btnNext.disabled = page >= total;

    tbody.innerHTML = slice
      .map(
        (r) => `
        <tr id="row-${r.idCarrito}">
          <td class="mono">${r.idCarrito}</td>
          <td class="mono">${r.vueloId}</td>
          <td>${r.nombre}</td>
          <td>${r.dni}</td>
          <td>${r.cantidad}</td>
          <td class="td-total">
            <span class="precio-val">${r.precioTotal.toFixed(2)}</span>
            <span class="precio-moneda">€</span>
          </td>
          <td>
            <button class="btn-del" data-id="${r.idCarrito}" data-nombre="${r.nombre}">
              Eliminar
            </button>
          </td>
        </tr>
      `
      )
      .join('');

    // Conecta los botones de eliminar para guardar el ID pendiente y abrir el dialog de confirmacion
    tbody.querySelectorAll<HTMLButtonElement>('.btn-del').forEach((btn) => {
      btn.addEventListener('click', () => {
        pendingId = btn.dataset.id!;
        dialogNombre.textContent = btn.dataset.nombre!;
        confirmDialog.style.display = 'flex';
      });
    });
  }

  // Obtiene todas las reservas de ZCARRITO_JMG a traves del proxy y actualiza el estado de la tabla
  async function loadReservas() {
    try {
      const res = await fetch(`${PROXY_URL}/api/admin/reservas`, {
        headers: { Authorization: `Bearer ${API_TOKEN}` },
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.error || 'Error del proxy');
      allReservas = json.data || [];
      filtered = allReservas;
      loadingEl.style.display = 'none';
      tableWrap.style.display = 'block';
      render();
    } catch (err: any) {
      loadingEl.style.display = 'none';
      errorEl.style.display = 'block';
      errorEl.textContent = `Error al cargar las reservas: ${err.message}`;
    }
  }

  // Gestiona el dialog de confirmacion: cancela la accion o ejecuta el DELETE contra el proxy y elimina la fila del DOM
  const confirmDialog = document.getElementById('confirm-dialog') as HTMLDivElement;
  const dialogNombre = document.getElementById('dialog-nombre') as HTMLSpanElement;
  let pendingId = '';

  document.getElementById('dialog-cancelar')!.addEventListener('click', () => {
    confirmDialog.style.display = 'none';
    pendingId = '';
  });

  document.getElementById('dialog-confirmar')!.addEventListener('click', async () => {
    if (!pendingId) return;
    const btn = document.getElementById('dialog-confirmar') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Eliminando…';

    const res = await fetch(`/api/admin/reservas/${pendingId}`, { method: 'DELETE' });
    const data = await res.json();

    if (data.ok) {
      document.getElementById(`row-${pendingId}`)?.remove();
      allReservas = allReservas.filter((r) => r.idCarrito !== pendingId);
      filtered = filtered.filter((r) => r.idCarrito !== pendingId);
      render();
    } else {
      alert(data.error || 'Error al eliminar.');
    }

    confirmDialog.style.display = 'none';
    pendingId = '';
    btn.disabled = false;
    btn.textContent = 'Sí, eliminar';
  });

  btnPrev.addEventListener('click', () => { page--; render(); });
  btnNext.addEventListener('click', () => { page++; render(); });
  searchInput.addEventListener('input', applyFilter);
  loadReservas();
</script>

<style>
  .admin-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 2rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .page-header h1 {
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #1e293b;
    margin-bottom: 0.2rem;
  }
  .subtitle { color: var(--texto-sec); font-size: 0.875rem; }

  .contador {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--texto-sec);
    background: #f1f5f9;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--borde);
    white-space: nowrap;
    margin-top: 0.3rem;
  }

  .toolbar {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    align-items: center;
  }
  .toolbar input {
    flex: 1;
    padding: 0.6rem 1rem;
    border: 1.5px solid var(--borde);
    border-radius: 8px;
    font-size: 0.875rem;
    font-family: inherit;
    outline: none;
    background: #fff;
    color: #1e293b;
    transition: border-color 0.15s;
  }
  .toolbar input:focus { border-color: var(--primario); }

  .table-card { overflow-x: auto; }

  .tabla-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem 0.9rem;
    border-bottom: 1px solid var(--borde);
  }
  .tabla-titulo { font-size: 0.92rem; font-weight: 700; color: #1e293b; }
  .tabla-info { font-size: 0.78rem; color: var(--texto-sec); }

  .tabla-scroll { overflow-x: auto; }

  table { width: 100%; border-collapse: collapse; font-size: 0.865rem; }
  thead tr { background: #f8fafc; border-bottom: 1px solid var(--borde); }
  thead th {
    padding: 0.7rem 1rem;
    text-align: left;
    font-size: 0.67rem;
    font-weight: 700;
    color: var(--texto-sec);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    white-space: nowrap;
  }
  tbody tr { transition: background 0.12s; }
  tbody tr:hover { background: #f8fafc; }
  td {
    padding: 0.95rem 1rem;
    border-bottom: 1px solid var(--borde);
    color: #1e293b;
    vertical-align: middle;
  }
  tbody tr:last-child td { border-bottom: none; }

  td.mono {
    font-family: monospace;
    font-size: 0.78rem;
    color: var(--texto-sec);
    letter-spacing: 0.01em;
  }

  .td-total { white-space: nowrap; }
  .precio-val { font-size: 1rem; font-weight: 700; color: var(--primario); }
  .precio-moneda { font-size: 0.72rem; color: var(--texto-sec); margin-left: 0.2rem; }

  .loading-state,
  .error-state {
    padding: 3.5rem;
    text-align: center;
    color: var(--texto-sec);
    font-size: 0.925rem;
  }
  .error-state { color: #dc2626; }

  .pie {
    display: flex;
    justify-content: flex-end;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--borde);
  }
  .paginacion { display: flex; align-items: center; gap: 0.5rem; }
  .pag-info {
    font-size: 0.8rem;
    color: var(--texto-sec);
    min-width: 3.5rem;
    text-align: center;
  }
  .pag-btn {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid var(--borde);
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    color: var(--texto-sec);
    transition: background 0.14s, border-color 0.14s, color 0.14s;
  }
  .pag-btn:hover:not(:disabled) { background: var(--primario); border-color: var(--primario); color: #fff; }
  .pag-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  /* Botón eliminar */
  .btn-del {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    background: transparent;
    color: #dc2626;
    border: 1.5px solid #fecaca;
    border-radius: 7px;
    font-size: 0.78rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.14s, border-color 0.14s;
  }
  .btn-del:hover { background: #fef2f2; border-color: #fca5a5; }
  .btn-del:disabled { opacity: 0.45; cursor: not-allowed; }

  /* Dialog de confirmación */
  .dialog-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.48);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 1rem;
  }
  .dialog-box {
    background: #fff;
    border-radius: 14px;
    padding: 1.75rem 2rem;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
  }
  .dialog-titulo {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .dialog-sub {
    font-size: 0.875rem;
    color: var(--texto-sec);
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }
  .dialog-sub strong { color: #1e293b; }
  .dialog-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
  }
  .dialog-btn-cancel {
    padding: 0.6rem 1.25rem;
    background: #fff;
    color: var(--texto-sec);
    border: 1.5px solid var(--borde);
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.1s;
  }
  .dialog-btn-cancel:hover { background: #f8fafc; }
  .dialog-btn-confirm {
    padding: 0.6rem 1.25rem;
    background: #dc2626;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .dialog-btn-confirm:hover { opacity: 0.88; }
  .dialog-btn-confirm:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
