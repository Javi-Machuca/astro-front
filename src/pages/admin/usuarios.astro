---
import Layout from '../../layouts/Layout.astro';
import { getAllUsers } from '../../lib/auth';

const currentUser = Astro.locals.user!;
const usuarios = getAllUsers();
---

<Layout titulo="Usuarios – Panel Admin">
  <div class="wrap">
    <header class="page-header">
      <div>
        <h1>Gestión de usuarios</h1>
        <p class="subtitle">
          {usuarios.length} cuenta{usuarios.length !== 1 ? 's' : ''} registrada{
            usuarios.length !== 1 ? 's' : ''
          }
        </p>
      </div>
    </header>

    <div id="toast" class="toast" style="display:none"></div>

    <div class="card table-card">
      <table>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Rol</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="users-tbody">
          {
            usuarios.map((u) => (
              <tr id={`row-${u.id}`}>
                <td class="name-cell">
                  <span class="avatar">{u.name.charAt(0).toUpperCase()}</span>
                  {u.name}
                  {u.id === currentUser.sub && (
                    <span class="you-badge">tú</span>
                  )}
                </td>
                <td class="email-cell">{u.email}</td>
                <td>
                  <span
                    class={`role-badge ${u.role === 'admin' ? 'badge-admin' : 'badge-user'}`}
                    id={`role-${u.id}`}
                  >
                    {u.role === 'admin' ? 'Admin' : 'Usuario'}
                  </span>
                </td>
                <td class="actions-cell">
                  {u.role === 'user' ? (
                    <button
                      class="btn-action btn-promote"
                      data-id={u.id}
                      data-action="promote"
                      title="Ascender a admin"
                    >
                      ↑ Hacer admin
                    </button>
                  ) : u.id !== currentUser.sub ? (
                    <button
                      class="btn-action btn-demote"
                      data-id={u.id}
                      data-action="demote"
                      title="Rebajar a usuario"
                    >
                      ↓ Quitar admin
                    </button>
                  ) : null}
                  {u.id !== currentUser.sub && (
                    <button
                      class="btn-action btn-delete"
                      data-id={u.id}
                      data-action="delete"
                      data-name={u.name}
                      title="Eliminar usuario"
                    >
                      Eliminar
                    </button>
                  )}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script>
  const toast = document.getElementById('toast') as HTMLDivElement;

  // Muestra un mensaje de éxito o error durante 3 segundos
  function showToast(msg: string, ok = true) {
    toast.textContent = msg;
    toast.className = 'toast ' + (ok ? 'toast-ok' : 'toast-err');
    toast.style.display = 'block';
    setTimeout(() => {
      toast.style.display = 'none';
    }, 3000);
  }

  // Delegación de eventos: detecta clics en los botones de acción de cualquier fila
  document
    .getElementById('users-tbody')!
    .addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest(
        '[data-action]'
      ) as HTMLButtonElement | null;
      if (!btn) return;

      const { id, action, name } = btn.dataset;
      if (!id || !action) return;

      if (action === 'delete') {
        if (
          !confirm(
            `¿Eliminar la cuenta de "${name}"? Esta acción no se puede deshacer.`
          )
        )
          return;
      }

      btn.disabled = true;

      // Cambio de rol: actualiza el badge y el botón en el DOM sin recargar la página
      if (action === 'promote' || action === 'demote') {
        const newRole = action === 'promote' ? 'admin' : 'user';
        const res = await fetch(`/api/admin/usuarios/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ role: newRole }),
        });
        const data = await res.json();
        if (data.ok) {
          // Actualizar badge y botones sin recargar
          const badge = document.getElementById(
            `role-${id}`
          ) as HTMLSpanElement;
          badge.textContent = newRole === 'admin' ? 'Admin' : 'Usuario';
          badge.className = `role-badge ${newRole === 'admin' ? 'badge-admin' : 'badge-user'}`;
          btn.outerHTML =
            newRole === 'admin'
              ? `<button class="btn-action btn-demote" data-id="${id}" data-action="demote" title="Rebajar a usuario">↓ Quitar admin</button>`
              : `<button class="btn-action btn-promote" data-id="${id}" data-action="promote" title="Ascender a admin">↑ Hacer admin</button>`;
          showToast(
            `Rol actualizado a ${newRole === 'admin' ? 'Admin' : 'Usuario'}.`
          );
        } else {
          showToast(data.error || 'Error al actualizar.', false);
          btn.disabled = false;
        }
      }

      // Eliminación: quita la fila del DOM si el servidor confirma el borrado
      if (action === 'delete') {
        const res = await fetch(`/api/admin/usuarios/${id}`, {
          method: 'DELETE',
        });
        const data = await res.json();
        if (data.ok) {
          document.getElementById(`row-${id}`)?.remove();
          showToast('Usuario eliminado.');
        } else {
          showToast(data.error || 'Error al eliminar.', false);
          btn.disabled = false;
        }
      }
    });
</script>

<style>
  .wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 2rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .page-header h1 {
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #1e293b;
    margin-bottom: 0.2rem;
  }
  .subtitle { color: var(--texto-sec); font-size: 0.875rem; }

  /* Toast */
  .toast {
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid transparent;
  }
  .toast-ok { background: #f0fdf4; color: #15803d; border-color: #bbf7d0; }
  .toast-err { background: #fef2f2; color: #dc2626; border-color: #fecaca; }

  /* Tabla */
  .table-card { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; }
  thead th {
    background: #f8fafc;
    border-bottom: 1px solid var(--borde);
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--texto-sec);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
  tbody tr {
    border-bottom: 1px solid var(--borde);
    transition: background 0.1s;
  }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: var(--fila-hover); }
  td {
    padding: 0.85rem 1rem;
    font-size: 0.875rem;
    color: #1e293b;
    vertical-align: middle;
  }

  .name-cell {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 500;
  }
  .email-cell { color: var(--texto-sec); font-size: 0.85rem; }

  .avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--primario);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .you-badge {
    font-size: 0.68rem;
    font-weight: 700;
    background: #eff6ff;
    color: #2563eb;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    letter-spacing: 0.03em;
  }

  .role-badge {
    display: inline-block;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .badge-admin { background: #ede9fe; color: #6d28d9; }
  .badge-user  { background: #f1f5f9; color: #475569; }

  .actions-cell {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .btn-action {
    padding: 0.3rem 0.8rem;
    border-radius: 7px;
    font-size: 0.78rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    border: 1.5px solid var(--borde);
    background: #fff;
    transition: all 0.1s;
  }
  .btn-action:disabled { opacity: 0.45; cursor: not-allowed; }

  .btn-promote { color: #6d28d9; border-color: #ddd6fe; }
  .btn-promote:hover { background: #ede9fe; border-color: #c4b5fd; }

  .btn-demote { color: #64748b; }
  .btn-demote:hover { background: #f1f5f9; }

  .btn-delete { color: #dc2626; border-color: #fecaca; }
  .btn-delete:hover { background: #fef2f2; border-color: #fca5a5; }
</style>
