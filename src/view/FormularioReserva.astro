---

---

<div id="formulario-overlay" style="display:none">
  <div class="modal">
    <button class="btn-cerrar-modal" id="btn-cerrar-form">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M18 6 6 18M6 6l12 12"></path>
      </svg>
    </button>

    <h2 class="modal-titulo">Reservar vuelo</h2>

    <div id="paso-1">
      <p class="paso-desc">¿Cuántos pasajeros van a viajar?</p>
      <div class="campo-grupo">
        <label for="num-pasajeros">Número de pasajeros</label>
        <input type="number" id="num-pasajeros" min="1" max="9" value="1" />
      </div>
      <button class="btn-primario" id="btn-continuar">Continuar</button>
    </div>

    <div id="paso-2" style="display:none">
      <div id="lista-pasajeros"></div>
      <div class="resumen-precio">
        <span>Total estimado:</span>
        <strong id="precio-total">—</strong>
      </div>
      <div id="error-completo" class="error-completo" style="display:none">
        Este vuelo esta completo y no admite mas reservas.
      </div>
      <div class="modal-acciones">
        <button class="btn-secundario" id="btn-volver-paso1">Volver</button>
        <button class="btn-primario" id="btn-añadir-carrito"
          >Añadir al carrito</button
        >
      </div>
    </div>
  </div>
</div>

<script>
  import type { Vuelo, Pasajero, ItemCarrito } from '../models/Vuelo';
  import { formatearPrecio, tieneDescuentoEdad } from '../models/Vuelo';

  const overlay = document.getElementById('formulario-overlay')!;
  const paso1 = document.getElementById('paso-1')!;
  const paso2 = document.getElementById('paso-2')!;
  const listaPax = document.getElementById('lista-pasajeros')!;
  const precioTot = document.getElementById('precio-total')!;
  const inputNum = document.getElementById('num-pasajeros') as HTMLInputElement;

  // Cerrar el modal al pulsar la X o hacer clic fuera
  document.getElementById('btn-cerrar-form')!.addEventListener('click', cerrar);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) cerrar();
  });

  // Resetea el modal a su estado inicial (paso 1, un pasajero)
  function cerrar() {
    overlay.style.display = 'none';
    paso1.style.display = 'block';
    paso2.style.display = 'none';
    inputNum.value = '1';
  }

  document.getElementById('btn-continuar')!.addEventListener('click', () => {
    const n = Math.max(1, Math.min(9, parseInt(inputNum.value) || 1));
    renderPasajeros(n);
    paso1.style.display = 'none';
    paso2.style.display = 'block';
  });

  document.getElementById('btn-volver-paso1')!.addEventListener('click', () => {
    paso1.style.display = 'block';
    paso2.style.display = 'none';
  });

  // Genera dinámicamente los campos de cada pasajero y conecta el listener de precio
  function renderPasajeros(n: number) {
    listaPax.innerHTML = Array.from(
      { length: n },
      (_, i) => `
      <div class="pasajero-bloque">
        <h3 class="pax-titulo">Pasajero ${i + 1}</h3>
        <div class="pax-grid">
          <div class="campo-grupo">
            <label>Nombre completo</label>
            <input type="text" class="pax-nombre" placeholder="Ej: Juan García" data-idx="${i}" />
          </div>
          <div class="campo-grupo">
            <label>DNI</label>
            <input type="text" class="pax-dni" placeholder="Ej: 12345678A" data-idx="${i}" />
          </div>
          <div class="campo-grupo">
            <label>Edad</label>
            <input type="number" class="pax-edad" min="0" max="120" placeholder="Ej: 35" data-idx="${i}" />
            <span class="descuento-info" id="desc-${i}" style="display:none">-30% descuento aplicado</span>
            <span class="edad-hint">Menores de 7 y mayores de 65 tienen un 30% de descuento</span>
          </div>
        </div>
      </div>
    `
    ).join('');

    // Actualizar precio al cambiar edad
    listaPax
      .querySelectorAll<HTMLInputElement>('.pax-edad')
      .forEach((input) => {
        input.addEventListener('input', actualizarPrecio);
      });

    actualizarPrecio();
  }

  // Recalcula el precio total aplicando descuentos por edad y actualiza el DOM
  function actualizarPrecio() {
    const vuelo: Vuelo = JSON.parse(
      sessionStorage.getItem('vuelo-reserva') || '{}'
    );
    if (!vuelo.precio) return;

    const edades = Array.from(
      listaPax.querySelectorAll<HTMLInputElement>('.pax-edad')
    ).map((i) => (i.value.trim() === '' ? NaN : parseInt(i.value, 10)));

    let total = 0;
    edades.forEach((edad, i) => {
      const tieneDescuento = tieneDescuentoEdad(edad);
      const precio = tieneDescuento ? vuelo.precio * 0.7 : vuelo.precio;
      total += precio;
      const info = document.getElementById(`desc-${i}`)!;
      info.style.display = tieneDescuento ? 'block' : 'none';
    });

    precioTot.textContent = `${formatearPrecio(total)} ${vuelo.moneda || 'EUR'}`;
  }

  document
    .getElementById('btn-añadir-carrito')!
    .addEventListener('click', () => {
      const vuelo: Vuelo = JSON.parse(
        sessionStorage.getItem('vuelo-reserva') || '{}'
      );
      if (!vuelo.codigoVuelo) return;

      if (vuelo.estado === 'Completo' || vuelo.plazasDisponibles === 0) {
        document.getElementById('error-completo')!.style.display = 'block';
        return;
      }

      // Extrae los valores de nombre, DNI y edad de los inputs generados dinamicamente
      const nombres = Array.from(
        listaPax.querySelectorAll<HTMLInputElement>('.pax-nombre')
      ).map((i) => i.value.trim());
      const dnis = Array.from(
        listaPax.querySelectorAll<HTMLInputElement>('.pax-dni')
      ).map((i) => i.value.trim());
      const edades = Array.from(
        listaPax.querySelectorAll<HTMLInputElement>('.pax-edad')
      ).map((i) => (i.value.trim() === '' ? NaN : parseInt(i.value, 10)));

      // Verifica que todos los campos de nombre, DNI y edad de cada pasajero esten completos y sean validos
      const invalido = nombres.some(
        (n, i) => !n || !dnis[i] || isNaN(edades[i]) || edades[i] < 0
      );
      if (invalido) {
        alert('Por favor rellena todos los campos de los pasajeros.');
        return;
      }

      const pasajeros: Pasajero[] = nombres.map((nombre, i) => ({
        nombre,
        dni: dnis[i],
        edad: edades[i],
      }));

      let total = 0;
      pasajeros.forEach((p) => {
        total += vuelo.precio * (tieneDescuentoEdad(p.edad) ? 0.7 : 1);
      });

      // Guardar en carrito (localStorage)
      const carrito: ItemCarrito[] = JSON.parse(
        localStorage.getItem('carrito') || '[]'
      );
      carrito.push({ vuelo, pasajeros, total });
      localStorage.setItem('carrito', JSON.stringify(carrito));

      cerrar();

      // Actualizar contador carrito
      const badge = document.getElementById('carrito-badge');
      if (badge) {
        badge.textContent = String(carrito.length);
        (badge as HTMLElement).style.display =
          carrito.length > 0 ? 'flex' : 'none';
      }

      // Feedback visual
      mostrarToast(`Vuelo ${vuelo.codigoVuelo} añadido al carrito`);
    });

  // Muestra una notificación flotante que desaparece tras 3 segundos
  function mostrarToast(msg: string) {
    const t = document.createElement('div');
    t.className = 'toast';
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.classList.add('toast-show'), 10);
    setTimeout(() => {
      t.classList.remove('toast-show');
      setTimeout(() => t.remove(), 300);
    }, 3000);
  }
</script>

<style>
  #formulario-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.48);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .modal {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    width: 100%;
    max-width: 640px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.22);
  }

  .btn-cerrar-modal {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: none;
    background: #f1f5f9;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--texto-sec);
    transition: background 0.15s;
  }
  .btn-cerrar-modal:hover { background: #e2e8f0; }

  .modal-titulo {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }
  .paso-desc {
    color: var(--texto-sec);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .campo-grupo {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .campo-grupo label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--texto-sec);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .campo-grupo input {
    padding: 0.65rem 0.9rem;
    border: 1.5px solid var(--borde);
    border-radius: 8px;
    font-size: 0.925rem;
    font-family: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    width: 100%;
    background: #fff;
  }
  .campo-grupo input:focus {
    border-color: var(--primario);
    box-shadow: 0 0 0 3px rgba(26, 46, 90, 0.1);
  }
  .campo-grupo input::placeholder { color: #b0b8c4; }

  .pasajero-bloque {
    background: #f8fafc;
    border: 1px solid var(--borde);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .pax-titulo {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--texto-sec);
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--borde);
    margin-bottom: 1rem;
  }
  .pax-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.75rem;
    align-items: start;
  }
  .edad-hint {
    font-size: 0.68rem;
    color: var(--texto-sec);
    font-style: italic;
    margin-top: 0.25rem;
    line-height: 1.4;
  }
  .descuento-info {
    font-size: 0.72rem;
    font-weight: 600;
    color: #166534;
    background: #dcfce7;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    margin-top: 0.25rem;
    width: fit-content;
  }

  .resumen-precio {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 10px;
    margin: 1rem 0;
    font-size: 0.925rem;
    color: #1e293b;
  }
  .resumen-precio strong {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--primario);
  }

  .error-completo {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .modal-acciones {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }

  .btn-primario {
    padding: 0.7rem 1.5rem;
    background: var(--primario);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.15s;
  }
  .btn-primario:hover { opacity: 0.87; }

  .btn-secundario {
    padding: 0.7rem 1.5rem;
    background: transparent;
    color: var(--texto-sec);
    border: 1.5px solid var(--borde);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
  }
  .btn-secundario:hover { background: #f1f5f9; }

  :global(.toast) {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(1rem);
    background: #1e293b;
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
    opacity: 0;
    transition: opacity 0.3s, transform 0.3s;
    z-index: 200;
    white-space: nowrap;
  }
  :global(.toast-show) {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>
